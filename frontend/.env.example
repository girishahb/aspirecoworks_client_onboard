# Backend API base URL (no trailing slash). Used for all API requests.
# Unset: production default https://api.aspirecoworks.in
# Local dev: set to http://localhost:3000
# VITE_API_URL=http://localhost:3000

# Razorpay Key ID (same as backend RAZORPAY_KEY_ID) - required for public booking checkout
# Local: use test key (rzp_test_xxx). Production: use live key (rzp_live_xxx).
# VITE_RAZORPAY_KEY_ID=rzp_test_xxxxx
# Alternative: VITE_RAZORPAY_KEY=rzp_test_xxxxx

# Optional: Website URL for "Visit Website" on booking success (default: /)
# VITE_WEBSITE_URL=https://aspirecoworks.in
